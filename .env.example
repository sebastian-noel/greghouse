# Copy to .env and fill in. .env is gitignored — never commit real values.

# Node server (server/index.js)
PORT=3000
GOOGLE_CLIENT_ID=
TELEMETRY_UPSTREAM=https://gg4ghv6ns8.execute-api.us-east-1.amazonaws.com/readings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Web Push (generate once with: npx web-push generate-vapid-keys --json)
# Use a contact URI such as mailto:you@example.com. Keep the private key secret.
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
